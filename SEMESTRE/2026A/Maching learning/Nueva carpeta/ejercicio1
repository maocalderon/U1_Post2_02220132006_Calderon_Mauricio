#ejercicio4

def edad_promedio(personas):
    edades = personas.values()
    return sum(edades) / len(edades)

# Ejemplo de uso
diccionario_edades = {"Ana": 20, "Luis": 25, "Carlos": 30}
print(edad_promedio(diccionario_edades)) # Salida: 25.0


#ejercicio5
def obtener_pares(lista):
    return [n for n in lista if n % 2 == 0]

# Prueba
print(obtener_pares([1, 2, 3, 4, 5, 6])) # Salida: [2, 4, 6] [ 17, 18]


