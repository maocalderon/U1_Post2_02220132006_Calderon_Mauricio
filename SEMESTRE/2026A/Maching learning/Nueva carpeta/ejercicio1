def invertir_tupla(tupla):
    return tupla[::-1]

# Prueba
print(invertir_tupla((1, 2, 3))) # Salida: (3, 2, 1) [ 20, 21]

#ejercicio7
def frecuencia_elementos(lista):
    return {f: lista.count(f) for f in set(lista)}

# Prueba
print(frecuencia_elementos([1, 2, 2, 3, 1, 1])) # Salida: {1: 3, 2: 2, 3: 1}

#ejercicio8
def aplicar_descuento(productos):
    for producto in productos:
        productos[producto] *= 0.90
    return productos

# Ejemplo de uso
tienda = {"camisa": 100, "pantalon": 200}
print(aplicar_descuento(tienda)) # Salida: {'camisa': 90.0, 'pantalon': 180.0}


#ejercicio9
def estudiantes_aprobados(lista_estudiantes):
    return [e["nombre"] for e in lista_estudiantes if e["nota"] >= 4.0]

# Prueba
datos = [{"nombre": "Ana", "nota": 4.5}, {"nombre": "Luis", "nota": 3.8}]
print(estudiantes_aprobados(datos)) # Salida: ['Ana'] [ 34, 35]


#ejercicio10
def combinar_listas(claves, valores):
    return dict(zip(claves, valores))

# Prueba
c = ["a", "b", "c"] # [ 38]
v = [1, 2, 3]       # [ 39]
print(combinar_listas(c, v)) # Salida: {'a': 1, 'b': 2, 'c': 3} [ 41]
